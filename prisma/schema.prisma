generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  hashedPassword String
  role           Role
  createdAt      DateTime @default(now())
  ECR            ECR[]
}

enum Role {
  DESIGNER
  COSTING
  PROJECTS
  QUALITY
  ADMIN
}

model Project {
  id     Int            @id @default(autoincrement())
  name   String
  scopes ProjectScope[]

  createdAt DateTime @default(now())
}

model ProjectScope {
  id        Int      @id @default(autoincrement())
  projectId Int
  scope     String?
  createdAt DateTime @default(now())
  ECR       ECR[]
  project   Project  @relation(fields: [projectId], references: [id])
}

enum ECRStatus {
  HOLD
  CANCELLED
  PENDING
  RELEASED
}

model WorkStage {
  id    Int    @id @default(autoincrement())
  name  String
  order Int
}

// model WorkFlow {
//   id    Int    @id @default(autoincrement())
//   name  String
//   order Int
// }

model ECR {
  id             Int           @id @default(autoincrement())
  title          String
  status         ECRStatus
  CRNumber       String
  ChangeDetails  String?
  receivedDate   DateTime
  CRBy           CRBy
  POReceivedDate DateTime? // required
  createdAt      DateTime      @default(now())
  projectId      Int?
  projectScope   ProjectScope? @relation(fields: [projectScopeId], references: [id])
  projectScopeId Int?
  user           User?         @relation(fields: [userId], references: [id])
  userId         Int?
}

enum CRBy {
  CUSTOMER
  INTERNAL
}
